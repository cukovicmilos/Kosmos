# Welcome and start messages
msgid "welcome_message"
msgstr "Dobrodošao u Kosmos! 🚀\n\nJa sam tvoj lični podsetnik. Pomažu ti da zapamtiš važne stvari.\n\nDa kreiraš podsetnik, samo mi pošalji poruku kao:\n• Kafa sutra 14:00\n• Sastanak pon 10:00\n• Pozovi Jovana 18:30\n\nKoristi /help da vidiš sve dostupne komande."

msgid "welcome_back"
msgstr "Dobrodošao nazad! 👋"

msgid "timezone_question"
msgstr "Nisam mogao da detektujem tvoju vremensku zonu. Molim te izaberi vremensku zonu:"

msgid "timezone_selected"
msgstr "Vremenska zona podešena na: {timezone}"

msgid "ready_to_use"
msgstr "Sve je spremno! 🎉\n\nKoristi dugmad ispod za brzi pristup, ili mi samo pošalji poruku da kreiraš podsetnik."

# Commands help
msgid "help_message"
msgstr "📖 *Kosmos Pomoć*\n\n*Kreiranje podsetnika:*\nPošalji poruku sa tekstom i vremenom:\n• `Tekst podsetnika sutra 16:00`\n• `Tekst podsetnika pon 10:00`\n• `Tekst podsetnika 14:30`\n\n*Ponavljajući podsetnoci:* 🔁\nKoristi /recurring da kreiraš podsetnike koji se automatski ponavljaju:\n• Svaki dan - Svakog dana u isto vreme\n• Svaki X dan - Ponavlja se svakih N dana\n• Nedeljno - Određeni dani (Pon, Sre, Pet...)\n• Mesečno - Određeni dan u mesecu\n\n*Podržani formati vremena:*\n• Dani: sutra, prekosutra, pon/uto/sre/cet/pet/sub/ned\n• Sledeća nedelja: sl pon/uto/sre/cet/pet/sub/ned\n• Vreme: 21:00, 8, 7am, 2100, itd.\n\n*Komande:*\n/list - Prikaži sve podsetnike u budućnosti\n/recurring - Kreiraj ponavljajući podsetnik\n/settings - Promeni jezik, format vremena, vremensku zonu\n/help - Prikaži ovu pomoć\n\n*Brze akcije:*\nKoristi dugmad 'List' i 'Ponavljajući' ispod za brzi pristup."

msgid "new_reminder_prompt"
msgstr "📝 Da kreiraš podsetnik, pošalji mi poruku u ovom formatu:\n\n`[Tvoj tekst podsetnika] [dan] [vreme]`\n\n*Primeri:*\n• Ponesi pecaljku na jezero sutra 16:00\n• Sastanak pon 10:00\n• Poziv sl pon 9:00\n• Kafa 14:30"

